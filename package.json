{
  "name": "gloss",
  "private": true,
  "packageManager": "bun@1.1.42",
  "engines": {
    "bun": ">=1.1.42",
    "node": ">=20.19.0 || >=22.12.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:api": "cd apps/api && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "build": "bun run build:shared && bun run build:api && bun run build:web",
    "build:shared": "cd packages/shared && bun run build",
    "build:api": "cd apps/api && bun run build",
    "build:web": "cd apps/web && bun run build",
    "lint": "bun run lint:shared && bun run lint:api && bun run lint:web && bun run lint:scripts",
    "lint:shared": "cd packages/shared && bun run lint",
    "lint:api": "cd apps/api && bun run lint",
    "lint:web": "cd apps/web && bun run lint",
    "lint:scripts": "bunx eslint scripts",
    "lint:boundaries": "bun run scripts/check-boundaries.ts",
    "harness:check": "bun run scripts/check-harness.ts",
    "typecheck": "bun run typecheck:shared && bun run typecheck:api && bun run typecheck:web && bun run typecheck:scripts",
    "typecheck:shared": "cd packages/shared && bun run typecheck",
    "typecheck:api": "cd apps/api && bun run typecheck",
    "typecheck:web": "cd apps/web && bun run typecheck",
    "typecheck:scripts": "bunx tsc -p tsconfig.scripts.json --noEmit",
    "test": "bun run test:shared && bun run test:api && bun run test:web",
    "test:unit": "bun run test:shared && bun run test:web",
    "test:integration": "bun run test:api",
    "test:shared": "cd packages/shared && bun run test",
    "test:api": "cd apps/api && bun run test",
    "test:web": "bun run scripts/run-web-tests.ts",
    "test:e2e": "bun run scripts/run-playwright.ts",
    "test:e2e:hosted": "bun run scripts/run-hosted-playwright.ts --grep @hosted",
    "test:e2e:live": "bun run scripts/run-live-browser-validation.ts --full",
    "smoke": "bun run scripts/run-playwright.ts --grep @smoke",
    "smoke:hosted": "bun run scripts/run-hosted-playwright.ts --grep @hosted",
    "smoke:live": "bun run scripts/run-live-browser-validation.ts",
    "eval": "bun run eval:journeys && bun run eval:traces",
    "eval:journeys": "bun run db:reset && bun run scripts/eval-journeys.ts",
    "eval:traces": "bun run db:reset && bun run scripts/eval-traces.ts",
    "eval:add-case": "bun run scripts/add-eval-case.ts",
    "report:alpha": "bun run scripts/report-private-alpha.ts",
    "deploy:check-env": "bun run scripts/check-deploy-env.ts",
    "db:start": "bun run scripts/db-start.ts",
    "db:stop": "bun run scripts/db-stop.ts",
    "db:migrate": "cd apps/api && bun run db:migrate",
    "db:seed": "bun run scripts/db-seed.ts",
    "db:reset": "bun run scripts/db-reset.ts",
    "fixtures:seed": "bun run scripts/db-seed.ts"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
